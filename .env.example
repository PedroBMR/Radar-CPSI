# Copie este arquivo para `.env` e preencha para rodar localmente.
# Em produção (GitHub Actions), estes valores vêm de GitHub Secrets — NUNCA commite o .env real.

# Token do seu bot do Telegram (fornecido pelo @BotFather).
TELEGRAM_BOT_TOKEN=123456789:AAExemplo-Token-Do-Seu-Bot

# ID do chat/usuário que receberá as notificações.
# Veja no README a seção "Como descobrir o chat_id".
TELEGRAM_CHAT_ID=987654321

# Opcional: desliga o envio real ao Telegram e só imprime no log (útil para testes).
# Deixe vazio ou remova para enviar de verdade.
RADAR_DRY_RUN=

# Opcional: caminho do banco SQLite (default: data/radar_cpsi.db).
# RADAR_DB_PATH=data/radar_cpsi.db
